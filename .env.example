# Healthcare Fax Marketing System - Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# FAX API - Telnyx (Recommended)
# =============================================================================
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_FAX_APP_ID=your_fax_application_id  # Connection ID from Misson Control
TELNYX_FAX_NUMBER=+15551234567             # Your Telnyx fax number (E.164)
TELNYX_BAA_SIGNED=true                     # Set to true after signing BAA

# =============================================================================
# FAX API - SRFax (Alternative)
# =============================================================================
# SRFAX_ACCESS_ID=your_access_id
# SRFAX_ACCESS_PWD=your_access_password
# SRFAX_ACCOUNT_NUMBER=your_account_number
# SRFAX_FAX_NUMBER=+15551234567

# =============================================================================
# WEBHOOK RECEIVER
# =============================================================================
WEBHOOK_PORT=8080
WEBHOOK_HOST=0.0.0.0
WEBHOOK_SECRET=your_random_secret_for_validation
WEBHOOK_BASE_URL=https://your-server.com  # Or ngrok URL for testing

# =============================================================================
# AI CONTENT GENERATION
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Or use OpenAI:
# OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# GOOGLE CLOUD (OCR)
# =============================================================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Or inline JSON (for serverless):
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# =============================================================================
# GOOGLE DRIVE
# =============================================================================
GDRIVE_INCOMING_FOLDER_ID=your_folder_id_for_incoming_faxes
GDRIVE_OUTGOING_FOLDER_ID=your_folder_id_for_sent_faxes
GDRIVE_ARCHIVE_FOLDER_ID=your_folder_id_for_archive

# =============================================================================
# GOHIGHLEVEL (GHL)
# =============================================================================
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_location_id
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret
GHL_INBOUND_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_INBOUND_HOOK_ID
GHL_OUTBOUND_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_OUTBOUND_HOOK_ID

# =============================================================================
# SENDER INFORMATION (Required for TCPA Compliance)
# =============================================================================
SENDER_NAME="Eye Care Center of Orange County"
SENDER_PHONE=+17145551234
SENDER_FAX=+17145551235
SENDER_ADDRESS="123 Main Street, Irvine, CA 92614"
SENDER_EMAIL=info@eyecarecenteroc.com
SENDER_OPTOUT_EMAIL=optout@eyecarecenteroc.com

# =============================================================================
# EMAIL NOTIFICATIONS (SMTP)
# =============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=your_app_specific_password

# =============================================================================
# DEVELOPMENT
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
